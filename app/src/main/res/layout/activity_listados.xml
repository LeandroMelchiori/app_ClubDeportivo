<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Bottom bar -->

    <!-- Contenido scrollable -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/blue_start"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:menu="@menu/menu_bottom_nav"
        app:labelVisibilityMode="labeled"
        app:itemHorizontalTranslationEnabled="false"
        app:itemIconTint="@color/black"
        app:itemTextColor="@color/black"
        app:itemIconSize="30dp"
        />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:fillViewport="true"
        android:paddingBottom="16dp"
        android:background="@color/card_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="40dp">

            <!-- Encabezado: Bienvenida + perfil -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvBienvenido"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bienvenido, Pepe"
                    android:textColor="@color/blue_accent"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivPerfil"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_person"
                    android:contentDescription="Icono perfil"
                    app:tint="@color/text_primary" />
            </LinearLayout>

            <!-- Fecha -->
            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jueves, 28 de Septiembre"
                android:textColor="@color/text_secondary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_gradient_blue"
                android:orientation="vertical"
                android:layout_marginTop="20dp">


            </LinearLayout>

            <!-- Botones de listados de clientes -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <!-- Boton listar vencimientos del dia -->
                <Button
                    android:id="@+id/btnListVencimientos"
                    android:layout_width="115dp"
                    android:layout_height="55dp"
                    android:layout_gravity="start"
                    android:padding="0dp"
                    android:background="@drawable/bg_chip_blue"
                    app:backgroundTint="#0099FF"
                    android:text="Vencimientos" />

                <!-- Boton listar socios -->
                <Button
                    android:id="@+id/btnListSocios"
                    android:layout_width="115dp"
                    android:layout_height="55dp"
                    android:layout_marginStart="10dp"
                    android:padding="0dp"
                    android:background="@drawable/bg_chip_blue"
                    app:backgroundTint="#0099FF"
                    android:text="Socios" />

                <!-- Boton listar no socios -->
                <Button
                    android:id="@+id/btnListNoSocios"
                    android:layout_width="115dp"
                    android:layout_height="55dp"
                    android:padding="0dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_blue"
                    app:backgroundTint="#0099FF"
                    android:text="No Socios" />
            </LinearLayout>

