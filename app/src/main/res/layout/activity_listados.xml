<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/bg_dark">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:background="@color/card_dark"
        android:fillViewport="true">

        <!-- Contenedor gral -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingTop="50dp"
            android:paddingRight="20dp">

            <!-- Encabezado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Texto bienvenida -->
                <TextView
                    android:id="@+id/tvBienvenida"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bienvenido"
                    android:textColor="@color/blue_accent"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <!-- Icono usuario -->
                <ImageView
                    android:id="@+id/ivPerfil"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="Icono perfil"
                    android:src="@drawable/ic_person"
                    app:tint="@color/text_primary" />
            </LinearLayout>

            <!-- Fecha -->
            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Jueves, 28 de Septiembre"
                android:textColor="@color/text_secondary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_gradient_blue"
                android:orientation="vertical">
            </LinearLayout>

            <!-- Botones de listados -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <!-- Boton listar vencimientos del dia -->
                <Button
                    android:id="@+id/btnListVencimientos"
                    android:layout_width="115dp"
                    android:layout_height="55dp"
                    android:layout_gravity="start"
                    android:background="@drawable/bg_chip_blue"
                    android:padding="0dp"
                    android:text="Vencimientos"
                    app:backgroundTint="#0099FF" />

                <!-- Boton listar socios -->
                <Button
                    android:id="@+id/btnListSocios"
                    android:layout_width="115dp"
                    android:layout_height="55dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_blue"
                    android:padding="0dp"
                    android:text="Socios"
                    app:backgroundTint="#0099FF" />

                <!-- Boton listar no socios -->
                <Button
                    android:id="@+id/btnListNoSocios"
                    android:layout_width="115dp"
                    android:layout_height="55dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_blue"
                    android:padding="0dp"
                    android:text="No Socios"
                    app:backgroundTint="#0099FF" />
            </LinearLayout>

            <!-- Buscar usuario por id segun la lista actual -->
            <SearchView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:queryHint="Buscar por nombre"
                android:background="@drawable/bg_input_gray"
                android:text="Buscar" />

            <!-- Fecha -->
            <TextView
                android:id="@+id/tvNombreLista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="5dp"
                android:text="Nombre Lista"
                android:paddingStart="20dp"
                android:textColor="@color/text_secondary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Listados -->
            <FrameLayout
                android:id="@+id/contenedorListas"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp">

                <!-- No socios -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNoSocios"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="5dp"
                    tools:listitem="@layout/item_nosocio"/>

                <!-- Socios -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSocios"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="5dp"
                    tools:listitem="@layout/item_nosocio"/>

                <!-- Vencimientos -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvVencimientos"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="5dp"
                    tools:listitem="@layout/item_nosocio"/>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/blue_start"
        app:itemGravity="center"
        app:itemHorizontalTranslationEnabled="false"
        app:itemIconSize="30dp"
        app:itemIconTint="@color/black"
        app:itemTextColor="@color/black"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav" />

</RelativeLayout>