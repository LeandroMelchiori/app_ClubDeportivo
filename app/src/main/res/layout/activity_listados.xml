                            android:orientation="vertical"
                            android:layout_marginBottom="15dp">

                            <!-- Nombre del cliente y estado de la cuenta -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginStart="20dp"
                                android:layout_marginEnd="20dp"
                                android:layout_marginTop="10dp">

                                <!-- Nombre e id de usuario -->
                                <LinearLayout
                                    android:layout_width="300dp"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="32dp"
                                        android:textColor="@color/bg_dark"
                                        android:textSize="26sp"
                                        android:textStyle="bold"
                                        android:text="Navarro, Javier" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="20dp"
                                        android:textColor="@color/bg_dark"
                                        android:textSize="16sp"
                                        android:text="#384838232" />
                                </LinearLayout>

                                <!-- Estado de la cuota -->
                                <View
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="10dp"
                                    android:layout_gravity="center_vertical"
                                    android:background="@drawable/bg_user_status"
                                    android:backgroundTint="@color/white_button"/>
                            </LinearLayout>

                            <!-- Informacion y Botones -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="20dp"
                                android:layout_marginEnd="20dp"
                                android:layout_marginBottom="15dp"
                                android:orientation="horizontal">

                                <!-- Informacion del pago y ultima fecha -->
                                <LinearLayout
                                    android:layout_width="240dp"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">
                                    <!-- Informacion del pago -->
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="10dp"
                                        android:textSize="22sp"
                                        android:textColor="@color/black"
                                        android:text="Sin deuda"/>

                                    <!-- Ultima fecha de pago -->
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="15dp"
                                        android:textSize="16sp"
                                        android:textColor="@color/black"
                                        android:text="Ultima pago: 28/08/2008"/>
                                </LinearLayout>

                                <!-- Botones de accion -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal">

                                    <!-- Boton pagar -->
                                    <Button
                                        android:layout_width="80dp"
                                        android:layout_height="40dp"
                                        android:padding="0dp"
                                        android:background="@drawable/bg_chip_blue"
                                        app:backgroundTint="@color/white_button"
                                        android:textColor="@color/black"
                                        android:text="Ser Socio" />

                                    <!-- Boton ver mas -->
                                    <Button
                                        android:onClick="onVerMasClick"
                                        android:layout_width="80dp"
                                        android:layout_height="40dp"
                                        android:layout_marginTop="7dp"
                                        android:padding="0dp"
                                        android:background="@drawable/bg_chip_blue"
                                        app:backgroundTint="#D9D9D9"
                                        android:textColor="@color/black"
                                        android:text="Ver mas" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </ScrollView>
            </FrameLayout>



        </LinearLayout>

    </ScrollView>

</RelativeLayout>